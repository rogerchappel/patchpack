{
  "name": "patchpack",
  "version": "0.1.0",
  "description": "Portable patch bundles for local-first agent handoffs.",
  "type": "module",
  "bin": {
    "patchpack": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/test/*.test.js",
    "pretest": "npm run build",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "patch",
    "git",
    "agent",
    "handoff",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
